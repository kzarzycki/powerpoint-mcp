{
  "name": "powerpoint-mcp",
  "version": "0.5.0",
  "description": "MCP server that lets AI assistants manipulate live PowerPoint presentations via Office.js",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "powerpoint-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "addin/",
    ".claude-plugin/",
    ".mcp.json",
    "skills/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kzarzycki/powerpoint-mcp.git"
  },
  "homepage": "https://github.com/kzarzycki/powerpoint-mcp#readme",
  "bugs": {
    "url": "https://github.com/kzarzycki/powerpoint-mcp/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "powerpoint",
    "office-js",
    "live-editing",
    "presentation",
    "claude"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "esbuild server/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs && esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node' --external:@modelcontextprotocol/sdk --external:ws --external:zod",
    "prepublishOnly": "npm run build",
    "setup": "bash scripts/setup.sh",
    "start": "node server/index.ts",
    "typecheck": "tsc --noEmit",
    "setup-certs": "mkdir -p certs && mkcert -cert-file certs/localhost.pem -key-file certs/localhost-key.pem localhost 127.0.0.1 ::1",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:setup-profile": "node --experimental-strip-types e2e/setup-profile.ts",
    "check": "biome check . && tsc --noEmit && vitest run",
    "version": "bash scripts/sync-version.sh",
    "release": "bash scripts/release.sh",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "sideload": "node scripts/sideload.mjs",
    "sideload:https": "node scripts/sideload.mjs --tls",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@xmldom/xmldom": "^0.8.11",
    "jszip": "^3.10.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "server/**/*.ts": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "addin/**/*.js": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "e2e/**/*.ts": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
