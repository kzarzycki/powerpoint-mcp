{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "files": {
    "includes": ["server/**/*.ts", "addin/**/*.js", "e2e/**/*.ts", "!.claude/**"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["e2e/**/*.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noEmptyPattern": "off",
            "noUnusedFunctionParameters": "off"
          }
        }
      }
    }
  ]
}
